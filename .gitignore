# Root .gitignore for MERN app

# Node modules
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build directories
dist/
build/
.next/
out/

# IDE files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Project specific
BackEnd/Uploads/*
!BackEnd/Uploads/.gitkeep
